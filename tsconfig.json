{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["vitest/globals", "svelte"],
    "skipLibCheck": true
  },
  "include": [
    "entrypoints/**/*.ts",
    "src/**/*.ts",
    "src/**/*.svelte",
    "tests/**/*.ts",
    "vitest.config.ts",
    "wxt.config.ts",
    "wxt-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    ".wxt",
    ".output",
    "dist"
  ]
}
